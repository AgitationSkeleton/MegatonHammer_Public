+// Megaton Hammer: warp into a level packed by the editor's "Playtest" action. The editor
+// writes its level as native OTR resources that override a chosen scene's archive paths
+// (mods/mh_playtest.o2r), so the scene already loads normally — this command just warps
+// there and optionally sets Link's age.  Usage: mh_playtest [sceneIdHex] [child|adult]
+static bool MhPlaytestHandler(std::shared_ptr<Ship::Console> Console, const std::vector<std::string>& args,
+                              std::string* output) {
+    if (gPlayState == nullptr) {
+        ERROR_MESSAGE("[SOH] Load a save file first, then run mh_playtest.");
+        return 1;
+    }
+
+    s32 sceneId = 0x52; // Megaton Hammer's default playtest slot
+    if (args.size() >= 2) {
+        try {
+            sceneId = std::stoi(args[1], nullptr, 16);
+        } catch ([[maybe_unused]] std::exception const& ex) {
+            ERROR_MESSAGE("[SOH] Scene id must be a hex number.");
+            return 1;
+        }
+    }
+
+    if (args.size() >= 3) {
+        if (args[2] == "adult") {
+            gSaveContext.linkAge = LINK_AGE_ADULT;
+        } else if (args[2] == "child") {
+            gSaveContext.linkAge = LINK_AGE_CHILD;
+        }
+    }
+
+    // Find any entrance that leads to the requested scene (spawn 0 is the table's first match).
+    s16 entrance = -1;
+    for (s16 i = 0; i < ENTR_MAX; i++) {
+        if (gEntranceTable[i].scene == sceneId) {
+            entrance = i;
+            break;
+        }
+    }
+    if (entrance < 0) {
+        ERROR_MESSAGE("[SOH] No entrance found for scene id 0x%X.", sceneId);
+        return 1;
+    }
+
+    gPlayState->nextEntranceIndex = entrance;
+    gPlayState->transitionTrigger = TRANS_TRIGGER_START;
+    gPlayState->transitionType = TRANS_TYPE_INSTANT;
+    gSaveContext.nextTransitionType = TRANS_TYPE_INSTANT;
+    return 0;
+}
