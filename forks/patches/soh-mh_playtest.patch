+// Megaton Hammer: apply a custom starting inventory (from the editor's inventory editor) onto a
+// fresh save. The payload is the "inv" object of mh/info: { hearts, tiers{...}, toggles[...] }.
+// Tiers grant everything up to the chosen level. Keys match Editor/InventoryCatalog (OoT).
+// #5: SoH stores zTargetSetting as a GLOBAL (cross-file) setting that SaveManager re-applies during the
+// file load that runs after our boot hook, clobbering the editor's choice. Remember it here and re-assert
+// it for the first ~90 frames in the scene (render probe). -1 = no custom value (debug/empty → leave as-is).
+static int sMhZTarget = -1;
+
+// #7: the editor's player name is encoded to the OoT filename charset and written at boot, but SoH's
+// SaveManager loads the save AFTER the boot hook and overwrites gSaveContext.playerName (a per-save field)
+// with the stored file's name — so the in-game name (e.g. in a textbox's MESSAGE_NAME) showed jumbled.
+// Stash the encoded bytes here and re-assert them for the first frames in-scene, exactly like sMhZTarget.
+static u8 sMhPlayerName[8];
+static bool sMhNameSet = false;
+
+static void MhApplyCustomInventory(const nlohmann::json& inv) {
+    int hearts = inv.value("hearts", 3);
+    gSaveContext.healthCapacity = (s16)(hearts * 16);
+    gSaveContext.health = gSaveContext.healthCapacity;
+
+    auto hasToggle = [&](const char* k) -> bool {
+        if (!inv.contains("toggles") || !inv["toggles"].is_array()) return false;
+        for (auto& t : inv["toggles"]) if (t.is_string() && t.get<std::string>() == k) return true;
+        return false;
+    };
+    auto tier = [&](const char* k) -> int {
+        if (inv.contains("tiers") && inv["tiers"].is_object() && inv["tiers"].contains(k))
+            return inv["tiers"][k].get<int>();
+        return 0;
+    };
+    auto amount = [&](const char* k) -> int {   // #13: varying-amount item count (0 = none)
+        if (inv.contains("amounts") && inv["amounts"].is_object() && inv["amounts"].contains(k))
+            return inv["amounts"][k].get<int>();
+        return 0;
+    };
+
+    // Swords: own every tier up to the selection, equip the highest.
+    int sw = tier("sword");
+    static const u8 swordOwn[]  = { EQUIP_INV_SWORD_KOKIRI, EQUIP_INV_SWORD_MASTER, EQUIP_INV_SWORD_BIGGORON };
+    static const u8 swordItem[] = { ITEM_SWORD_KOKIRI, ITEM_SWORD_MASTER, ITEM_SWORD_BGS };
+    static const u8 swordVal[]  = { EQUIP_VALUE_SWORD_KOKIRI, EQUIP_VALUE_SWORD_MASTER, EQUIP_VALUE_SWORD_BIGGORON };
+    for (int i = 0; i < sw && i < 3; i++)
+        gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_SWORD, swordOwn[i]);
+    if (sw > 0) {
+        gSaveContext.equips.buttonItems[0] = swordItem[sw - 1];
+        gSaveContext.equips.equipment &= ~(0xF << (EQUIP_TYPE_SWORD * 4));
+        gSaveContext.equips.equipment |= swordVal[sw - 1] << (EQUIP_TYPE_SWORD * 4);
+    }
+    // #10: the BGS slot shows the breakable Giant's Knife (broken icon) unless bgsFlag is set; for
+    // Biggoron tier, set bgsFlag + full swordHealth so the player actually gets Biggoron's Sword.
+    if (sw >= 3) { gSaveContext.bgsFlag = true; gSaveContext.swordHealth = 8; }
+    else { gSaveContext.bgsFlag = false; }
+
+    // Shields: own up to tier, equip the highest (EQUIP_VALUE_SHIELD_DEKU = 1).
+    int sh = tier("shield");
+    static const u8 shieldOwn[] = { EQUIP_INV_SHIELD_DEKU, EQUIP_INV_SHIELD_HYLIAN, EQUIP_INV_SHIELD_MIRROR };
+    for (int i = 0; i < sh && i < 3; i++)
+        gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_SHIELD, shieldOwn[i]);
+    if (sh > 0) {
+        gSaveContext.equips.equipment &= ~(0xF << (EQUIP_TYPE_SHIELD * 4));
+        gSaveContext.equips.equipment |= sh << (EQUIP_TYPE_SHIELD * 4);
+    }
+
+    // Tunics & boots (Kokiri always owned + equipped; add the others on request).
+    gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_TUNIC, EQUIP_INV_TUNIC_KOKIRI);
+    gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_BOOTS, EQUIP_INV_BOOTS_KOKIRI);
+    if (hasToggle("tunic_goron")) gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_TUNIC, EQUIP_INV_TUNIC_GORON);
+    if (hasToggle("tunic_zora"))  gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_TUNIC, EQUIP_INV_TUNIC_ZORA);
+    if (hasToggle("boots_iron"))  gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_BOOTS, EQUIP_INV_BOOTS_IRON);
+    if (hasToggle("boots_hover")) gSaveContext.inventory.equipment |= OWNED_EQUIP_FLAG(EQUIP_TYPE_BOOTS, EQUIP_INV_BOOTS_HOVER);
+    gSaveContext.equips.equipment &= ~(0xF << (EQUIP_TYPE_TUNIC * 4));
+    gSaveContext.equips.equipment |= 1 << (EQUIP_TYPE_TUNIC * 4);   // EQUIP_VALUE_TUNIC_KOKIRI
+    gSaveContext.equips.equipment &= ~(0xF << (EQUIP_TYPE_BOOTS * 4));
+    gSaveContext.equips.equipment |= 1 << (EQUIP_TYPE_BOOTS * 4);   // EQUIP_VALUE_BOOTS_KOKIRI
+
+    // #21: injected player name (default "Link"). OoT filename encoding: 0-9=0x00.., A-Z=0x0A..,
+    // a-z=0x24.., space/other=0x3E; padded to 8. Without it the save name is blank.
+    {
+        std::string pn = inv.value("playerName", std::string("Link"));
+        if (pn.empty()) pn = "Link";
+        for (int i = 0; i < 8; i++) {
+            u8 c = 0x3E;
+            if (i < (int)pn.size()) {
+                char ch = pn[i];
+                if (ch >= '0' && ch <= '9') c = (u8)(ch - '0');
+                else if (ch >= 'A' && ch <= 'Z') c = (u8)(0x0A + (ch - 'A'));
+                else if (ch >= 'a' && ch <= 'z') c = (u8)(0x24 + (ch - 'a'));
+            }
+            gSaveContext.playerName[i] = c;
+            sMhPlayerName[i] = c;   // stash so the render probe can re-assert after SaveManager's load
+        }
+        sMhNameSet = true;
+    }
+
+    // #5: Z-targeting mode (0 = Switch/Toggle, 1 = Hold). Stash it so the render probe can re-assert it
+    // after SoH's global-settings load (which runs later in the boot) reverts this write.
+    sMhZTarget = inv.value("zTarget", 0);
+    gSaveContext.zTargetSetting = (u8)sMhZTarget;
+
+    // Ocarina tier.
+    int oc = tier("ocarina");
+    if (oc == 1) INV_CONTENT(ITEM_OCARINA_FAIRY) = ITEM_OCARINA_FAIRY;
+    else if (oc >= 2) INV_CONTENT(ITEM_OCARINA_TIME) = ITEM_OCARINA_TIME;
+
+    // Magic tier: 1 = single (the first upgrade), 2 = double. Same fields BossRush/debugSaveEditor set:
+    // flag acquired, set magicLevel, derive magicCapacity = level*0x30 so the bar draws, fill the meter.
+    int mg = tier("magic");
+    if (mg >= 1) {
+        gSaveContext.isMagicAcquired = 1;
+        gSaveContext.magicLevel = (mg >= 2) ? 2 : 1;
+        if (mg >= 2) gSaveContext.isDoubleMagicAcquired = 1;
+        gSaveContext.magicCapacity = gSaveContext.magicLevel * 0x30;   // draw the bar (debugSaveEditor)
+        gSaveContext.magic = gSaveContext.magicCapacity;
+    }
+
+    // Upgrades (wallet / strength / scale / quiver / bomb bag / bullet bag).
+    if (tier("wallet"))    Inventory_ChangeUpgrade(UPG_WALLET, tier("wallet"));
+    if (tier("strength"))  Inventory_ChangeUpgrade(UPG_STRENGTH, tier("strength"));
+    if (tier("scale"))     Inventory_ChangeUpgrade(UPG_SCALE, tier("scale"));
+    if (tier("quiver"))    Inventory_ChangeUpgrade(UPG_QUIVER, tier("quiver"));
+    if (tier("bombbag"))   Inventory_ChangeUpgrade(UPG_BOMB_BAG, tier("bombbag"));
+    if (tier("bulletbag")) Inventory_ChangeUpgrade(UPG_BULLET_BAG, tier("bulletbag"));
+
+    // C-items (with a sensible starting ammo where applicable).
+    struct ItemDef { const char* key; u8 item; s8 ammo; };
+    static const ItemDef kItems[] = {
+        { "stick", ITEM_STICK, 10 }, { "nut", ITEM_NUT, 20 }, { "bomb", ITEM_BOMB, 20 }, { "bow", ITEM_BOW, 30 },
+        { "fire_arrow", ITEM_ARROW_FIRE, 0 }, { "dins_fire", ITEM_DINS_FIRE, 0 }, { "slingshot", ITEM_SLINGSHOT, 30 },
+        { "bombchu", ITEM_BOMBCHU, 20 }, { "hookshot", ITEM_HOOKSHOT, 0 }, { "ice_arrow", ITEM_ARROW_ICE, 0 },
+        { "farores_wind", ITEM_FARORES_WIND, 0 }, { "boomerang", ITEM_BOOMERANG, 0 }, { "lens", ITEM_LENS, 0 },
+        { "bean", ITEM_BEAN, 10 }, { "hammer", ITEM_HAMMER, 0 }, { "light_arrow", ITEM_ARROW_LIGHT, 0 },
+        { "nayrus_love", ITEM_NAYRUS_LOVE, 0 },
+    };
+    for (auto& it : kItems)
+        if (hasToggle(it.key)) { INV_CONTENT(it.item) = it.item; if (it.ammo) AMMO(it.item) = it.ammo; }
+    if (hasToggle("bottle")) INV_CONTENT(ITEM_BOTTLE) = ITEM_BOTTLE;
+
+    // #13: varying-amount items — the editor's count spinner sets ammo[] and auto-grants the smallest
+    // capacity upgrade able to hold it (merged with the explicit tier upgrades above; highest wins).
+    struct AmmoDef { const char* key; u8 item; int upg; u8 caps[4]; };
+    static const AmmoDef kAmmo[] = {
+        { "stick", ITEM_STICK, UPG_STICKS, {0,10,20,30} }, { "nut", ITEM_NUT, UPG_NUTS, {0,20,30,40} },
+        { "bomb", ITEM_BOMB, UPG_BOMB_BAG, {0,20,30,40} },     { "bow", ITEM_BOW, UPG_QUIVER, {0,30,40,50} },
+        { "slingshot", ITEM_SLINGSHOT, UPG_BULLET_BAG, {0,30,40,50} }, { "bombchu", ITEM_BOMBCHU, -1, {0,50,50,50} },
+    };
+    for (auto& a : kAmmo) {
+        int amt = amount(a.key);
+        if (amt <= 0) continue;
+        if (amt > a.caps[3]) amt = a.caps[3];
+        INV_CONTENT(a.item) = a.item;
+        AMMO(a.item) = (s8)amt;
+        if (a.upg >= 0) {
+            int lvl = 3;
+            for (int l = 1; l < 4; l++) if (a.caps[l] >= amt) { lvl = l; break; }
+            if (lvl > CUR_UPG_VALUE(a.upg)) Inventory_ChangeUpgrade((u16)a.upg, lvl);
+        }
+    }
+
+    // Songs / medallions / stones (quest-item bits).
+    struct QuestDef { const char* key; int q; };
+    static const QuestDef kQuest[] = {
+        { "song_lullaby", QUEST_SONG_LULLABY }, { "song_epona", QUEST_SONG_EPONA }, { "song_saria", QUEST_SONG_SARIA },
+        { "song_suns", QUEST_SONG_SUN }, { "song_time", QUEST_SONG_TIME }, { "song_storms", QUEST_SONG_STORMS },
+        { "song_minuet", QUEST_SONG_MINUET }, { "song_bolero", QUEST_SONG_BOLERO }, { "song_serenade", QUEST_SONG_SERENADE },
+        { "song_requiem", QUEST_SONG_REQUIEM }, { "song_nocturne", QUEST_SONG_NOCTURNE }, { "song_prelude", QUEST_SONG_PRELUDE },
+        { "med_forest", QUEST_MEDALLION_FOREST }, { "med_fire", QUEST_MEDALLION_FIRE }, { "med_water", QUEST_MEDALLION_WATER },
+        { "med_spirit", QUEST_MEDALLION_SPIRIT }, { "med_shadow", QUEST_MEDALLION_SHADOW }, { "med_light", QUEST_MEDALLION_LIGHT },
+        { "stone_emerald", QUEST_KOKIRI_EMERALD }, { "stone_ruby", QUEST_GORON_RUBY }, { "stone_sapphire", QUEST_ZORA_SAPPHIRE },
+        { "agony", QUEST_STONE_OF_AGONY },
+    };
+    for (auto& qq : kQuest)
+        if (hasToggle(qq.key)) gSaveContext.inventory.questItems |= (1 << qq.q);
+
+    // Trade-quest slots (the editor's trade_child / trade_adult dropdowns). The OoT trade slots each hold
+    // one item id: child slot = ITEM 0x20+idx (Weird Egg 0x21 .. Mask of Truth 0x2B), adult slot =
+    // 0x2C+idx (Pocket Egg 0x2D .. Claim Check 0x37). Without this the editor's chosen trade item (e.g.
+    // Bunny Hood) never reached the OTR save — only the N64 poke path applied it.
+    int tradeChild = tier("trade_child");
+    if (tradeChild > 0) gSaveContext.inventory.items[SLOT_TRADE_CHILD] = (u8)(0x20 + tradeChild);
+    int tradeAdult = tier("trade_adult");
+    if (tradeAdult > 0) gSaveContext.inventory.items[SLOT_TRADE_ADULT] = (u8)(0x2C + tradeAdult);
+
+    // Dump the resulting save fields so the editor can verify injection end-to-end via the boot log.
+    MhBootLog("[mh_inv] applied: healthCap=" + std::to_string(gSaveContext.healthCapacity) +
+              " equipment=0x" + StringHelper::Sprintf("%X", gSaveContext.inventory.equipment) +
+              " upgrades=0x" + StringHelper::Sprintf("%X", gSaveContext.inventory.upgrades) +
+              " questItems=0x" + StringHelper::Sprintf("%X", gSaveContext.inventory.questItems) +
+              " ocarinaSlot=" + std::to_string(INV_CONTENT(ITEM_OCARINA_FAIRY)) +
+              " bSword=" + std::to_string(gSaveContext.equips.buttonItems[0]) +
+              " bgsFlag=" + std::to_string(gSaveContext.bgsFlag) +
+              " name0=" + std::to_string(gSaveContext.playerName[0]));
+}
