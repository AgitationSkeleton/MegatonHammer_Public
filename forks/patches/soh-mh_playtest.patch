+// Megaton Hammer: on title-screen startup, if a playtest mod O2R is mounted (it carries an
+// "mh/info" resource), set up a save and warp straight into the packed scene with the chosen
+// age + inventory — no manual console command. Modelled on Enhancements/Warping.cpp's boot path.
+// ── Authored dialogue (Megaton Hammer Message Bank) ───────────────────────────────────────────────
+// The editor emits an "mh/messages" resource: a JSON array of { id (textId), type, pos, icon, text }.
+// At boot we register an OnOpenText hook per id; when an actor opens that textId we build the line with
+// the friendly-markup converter (& newline, ^ new box, %r/%g/%b/%y/%w/%p colour) and load it into the font,
+// telling the engine to skip the normal message-table lookup.
+struct MhMsgEntry {
+    std::string text;
+    int type;
+    int pos;
+};
+static std::unordered_map<uint16_t, MhMsgEntry> sMhMessages;
+
+static void MhOnOpenText(uint16_t* textId, bool* loadFromMessageTable) {
+    auto it = sMhMessages.find(*textId);
+    if (it == sMhMessages.end()) {
+        return; // not an authored id → let the normal table handle it
+    }
+    CustomMessage msg(it->second.text, (TextBoxType)it->second.type, (TextBoxPosition)it->second.pos);
+    msg.AutoFormat();
+    msg.LoadIntoFont();
+    *loadFromMessageTable = false;
+}
+
+static void MhLoadMessages() {
+    auto ctx = Ship::Context::GetRawInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) {
+        return;
+    }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/messages");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) {
+        return; // no authored dialogue in this mod
+    }
+    std::string body(file->Buffer->begin(), file->Buffer->end());
+    nlohmann::json arr = nlohmann::json::parse(body, nullptr, false);
+    if (arr.is_discarded() || !arr.is_array()) {
+        MhBootLog("[mh_boot] mh/messages JSON parse error");
+        return;
+    }
+    int count = 0;
+    for (auto& e : arr) {
+        uint16_t id = (uint16_t)e.value("id", 0);
+        if (id == 0) {
+            continue;
+        }
+        sMhMessages[id] = MhMsgEntry{ e.value("text", std::string("")), e.value("type", 0), e.value("pos", 0) };
+        GameInteractor::Instance->RegisterGameHookForID<GameInteractor::OnOpenText>(id, MhOnOpenText);
+        count++;
+    }
+    MhBootLog("[mh_msg] registered " + std::to_string(count) + " authored message(s)");
+}
+
+// #20: the debug scene-select list's appended Megaton Hammer entry name (defined in ovl_select/z_select.c).
+extern "C" char gMhWarpName[64];
+
+// Cross-game / custom music: the runtime seqId->resource-path map, built by AudioLoad_Init from the archives.
+// The boot hook force-rebinds a host slot to the editor's injected OSEQ resource (see MhPlaytestBootHook).
+extern "C" char** sequenceMap;
+extern "C" size_t sequenceMapSize;
+
+static void MhPlaytestBootHook(void* gameState) {
+    static bool done = false;
+    if (done) {
+        return;
+    }
+
+    auto ctx = Ship::Context::GetRawInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) {
+        return;
+    }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/info");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) {
+        return; // no playtest mod present → normal boot
+    }
+    done = true;
+
+    MhLoadMessages();   // register any authored dialogue (mh/messages) before warping in
+
+    std::string info(file->Buffer->begin(), file->Buffer->end());
+    MhBootLog("[mh_boot] mh/info loaded: " + info);
+
+    nlohmann::json j = nlohmann::json::parse(info, nullptr, false);
+    if (j.is_discarded()) {
+        MhBootLog("[mh_boot] FAIL: mh/info JSON parse error");
+        return;
+    }
+    s32 sceneId = j.value("sceneId", 0x52);
+    bool adult = j.value("adult", false);
+    bool append = j.value("append", false);
+    std::string inv = j.value("inventory", std::string("debug"));
+    MhBootLog("[mh_boot] sceneId=0x" + StringHelper::Sprintf("%X", sceneId) + " adult=" +
+              std::to_string(adult) + " inventory=" + inv + " append=" + std::to_string(append));
+
+    // Megaton Hammer water scroll: OoT animates water via the scene's DRAW CONFIG. SDC_CALM_WATER (0x2F)
+    // scrolls segment 0x08 (a two-layer tile scroll on POLY_XLU_DISP), which the editor's translucent water
+    // DL (mesh xlu path) references via gsSPDisplayList(0x08). gSceneTable[id].config is read at spawn
+    // (OTRPlay_SpawnScene), so set it here on the scene the water level loads into. Only when the editor
+    // marked the level as having scrolling water (else leave the scene's own draw config untouched).
+    if (j.value("waterScroll", false)) {
+        s32 wsScene = append ? SCENE_MH_APPEND : sceneId;
+        gSceneTable[wsScene].config = 0x2F; // SDC_CALM_WATER
+        MhBootLog("[mh_boot] waterScroll: gSceneTable[0x" + StringHelper::Sprintf("%X", wsScene) +
+                  "].config = SDC_CALM_WATER");
+    }
+
+    // Megaton Hammer cross-game / custom music: the editor packed the chosen sequence as an OSEQ resource
+    // (audio/sequences/mh_cross) that claims a valid vanilla host seqId, and recorded it in mh/info "music".
+    // AudioLoad_Init already built sequenceMap from every archive, but two resources sharing a seqNumber are
+    // last-writer-wins (nondeterministic). Force the host slot to our resource so the scene's 0x15 (which the
+    // editor set to that same host id) resolves to the injected track. The level is custom, so displacing that
+    // vanilla sequence for this session is harmless.
+    if (j.contains("music") && j["music"].is_object() && sequenceMap != nullptr) {
+        int mSeq = j["music"].value("seqId", -1);
+        std::string mPath = j["music"].value("path", std::string());
+        if (mSeq >= 0 && (size_t)mSeq < sequenceMapSize && !mPath.empty()) {
+            if (sequenceMap[mSeq] != nullptr) {
+                free(sequenceMap[mSeq]);
+            }
+            sequenceMap[mSeq] = strdup(mPath.c_str());
+            MhBootLog("[mh_boot] music: sequenceMap[0x" + StringHelper::Sprintf("%X", mSeq) + "] -> " + mPath);
+        } else {
+            MhBootLog("[mh_boot] music: invalid seqId/path (seqId=" + std::to_string(mSeq) +
+                      ", mapSize=" + std::to_string(sequenceMapSize) + ")");
+        }
+    }
+
+    // #20: label this level at the tail of the debug scene-select list (default "Megaton Project").
+    {
+        std::string dn = j.value("displayName", std::string("Megaton Project"));
+        if (dn.empty()) dn = "Megaton Project";
+        snprintf(gMhWarpName, sizeof(gMhWarpName), "126:%.58s", dn.c_str());
+        MhBootLog("[mh_boot] warp-list name = " + std::string(gMhWarpName));
+    }
+
+    // Resolve the warp entrance. Append mode targets the reserved SCENE_MH_APPEND scene, reached via
+    // the reserved ENTR_MH_APPEND_0 entrance — both added to the (grown) scene/entrance tables in the
+    // Megaton Hammer fork, so nothing existing is repurposed. gSceneTable[SCENE_MH_APPEND] already
+    // references scenes/shared/mh_append_scene/mh_append_scene, which our mod O2R overrode with the
+    // appended level. Replace mode finds the first entrance that leads to the chosen real scene.
+    s16 entrance = -1;
+    if (append) {
+        entrance = ENTR_MH_APPEND_0;
+        MhBootLog("[mh_boot] append mode — warping via reserved ENTR_MH_APPEND_0 -> SCENE_MH_APPEND");
+    } else {
+        for (s16 i = 0; i < ENTR_MAX; i++) {
+            if (gEntranceTable[i].scene == sceneId) {
+                entrance = i;
+                break;
+            }
+        }
+        if (entrance < 0) {
+            ERROR_MESSAGE("[SOH] No entrance found for scene id 0x%X.", sceneId);
+            MhBootLog("[mh_boot] FAIL: no entrance for replace-mode scene 0x" + StringHelper::Sprintf("%X", sceneId));
+            return;
+        }
+    }
+    MhBootLog("[mh_boot] entrance=0x" + StringHelper::Sprintf("%X", entrance));
+
+    // Boot a temporary save (debug inventory, or empty), set age, and warp — mirrors Warping.cpp.
+    gSaveContext.gameMode = GAMEMODE_NORMAL;
+    gSaveContext.fileNum = 0xFE;
+    if (inv == "empty") {
+        Sram_InitNewSave();
+    } else if (inv == "custom") {
+        Sram_InitNewSave();   // start blank, then layer on the editor's custom loadout
+        if (j.contains("inv") && j["inv"].is_object()) {
+            MhApplyCustomInventory(j["inv"]);
+            MhBootLog("[mh_boot] applied custom inventory");
+        } else {
+            MhBootLog("[mh_boot] custom inventory selected but no 'inv' payload — left empty");
+        }
+    } else {
+        Sram_InitDebugSave(); // "debug" → full debug inventory
+    }
+    gSaveContext.fileNum = 0xFF;
+    gSaveContext.sceneSetupIndex = 0;
+    gSaveContext.cutsceneIndex = 0;
+    gSaveContext.linkAge = adult ? 0 : 1; // LINK_AGE_ADULT = 0, LINK_AGE_CHILD = 1
+    // Normalized playtest time-of-day (editor SceneSettings.PlaytestTimeOfDay): one u16 over a 24h day
+    // from midnight (0x8000=noon), the same value 2Ship applies to save.time — so every engine starts at
+    // the identical time. nightFlag follows it (0x4000..0xC000 ≈ 6:00..18:00 is day).
+    u16 mhTimeOfDay = (j.contains("timeOfDay") && j["timeOfDay"].is_number_integer())
+                          ? (u16)j["timeOfDay"].get<int>() : 0x8000;
+    gSaveContext.nightFlag = (mhTimeOfDay < 0x4555 || mhTimeOfDay > 0xC000) ? 1 : 0;
+    gSaveContext.skyboxTime = gSaveContext.dayTime = mhTimeOfDay;
+    for (int b = 0; b < ARRAY_COUNT(gSaveContext.buttonStatus); b++) {
+        gSaveContext.buttonStatus[b] = BTN_ENABLED;
+    }
+
+    // MH playtest gamestate normalization: every authored chest must start closed and every switch
+    // unpressed. Sram_InitDebugSave (and a loaded save) can leave the test scene's chest/switch flags
+    // set, so En_Box would render already-opened. Mirror the 2Ship hook and the N64 PJ64 Play_Init
+    // detour (which zero these wholesale) by clearing chest+swch for every scene. clear/collect/floors
+    // are left as-is (room-clear/collectible/map state isn't part of a chest's open/closed identity).
+    for (int i = 0; i < ARRAY_COUNT(gSaveContext.sceneFlags); i++) {
+        gSaveContext.sceneFlags[i].chest = 0;
+        gSaveContext.sceneFlags[i].swch = 0;
+    }
+
+    gSaveContext.entranceIndex = entrance;
+    gSaveContext.seqId = (u8)NA_BGM_DISABLED;
+    gSaveContext.natureAmbienceId = 0xFF;
+    gSaveContext.showTitleCard = true;
+    gWeatherMode = 0;
+
+    TitleContext* titleContext = (TitleContext*)gameState;
+    titleContext->state.running = false;
+    SET_NEXT_GAMESTATE(&titleContext->state, Play_Init, PlayState);
+    GameInteractor_ExecuteOnLoadGame(gSaveContext.fileNum);
+    MhBootLog("[mh_boot] OK: warp triggered to scene 0x" + StringHelper::Sprintf("%X", sceneId));
+}
+
+// MH render probe: once we've actually entered the playtest scene and run a few frames, log it once.
+// Positive confirmation the level loaded AND is rendering frames (not just that the warp fired) — lets
+// the headless harness distinguish a real load from a post-warp freeze.
+static void MhPlaytestRenderProbe() {
+    static int framesInScene = 0;
+    static bool logged = false;
+    if (gPlayState == nullptr) {
+        return;
+    }
+    if (gPlayState->sceneNum != SCENE_MH_APPEND) {
+        framesInScene = 0;
+        return;
+    }
+    framesInScene++;
+    // Re-assert the name EVERY frame in the playtest scene (not just the first 90): a textbox's
+    // MESSAGE_NAME can open at any time, and SaveManager may re-sync the save more than once.
+    if (sMhNameSet) {
+        for (int i = 0; i < 8; i++) gSaveContext.playerName[i] = sMhPlayerName[i];
+    }
+    if (sMhZTarget >= 0 && framesInScene <= 90) {
+        gSaveContext.zTargetSetting = (u8)sMhZTarget;
+    }
+    if (logged) {
+        return;
+    }
+    if (framesInScene >= 30) {
+        MhBootLog("[mh_boot] RENDER OK: in SCENE_MH_APPEND room=" +
+                  std::to_string((int)gPlayState->roomCtx.curRoom.num) + " after 30 frames");
+        // MH diag: the user reports a black sky + an untextured "blue blob" Link in this scene. Log the
+        // skybox + player + tunic state so the cause (skybox never set up / wrong id / Link draw) is
+        // visible in the boot log without a debugger. play->skyboxId is the scene's requested skybox
+        // (should be 1 = SKYBOX_NORMAL_SKY); skyboxCtx.skyboxId is what actually got loaded.
+        Player* mhPlayer = GET_PLAYER(gPlayState);
+        MhBootLog("[mh_diag] skyboxId=" + std::to_string((int)gPlayState->skyboxId) +
+                  " skyboxCtx.skyboxId=" + std::to_string((int)gPlayState->skyboxCtx.skyboxId) +
+                  " player=" + (mhPlayer ? "yes" : "NULL") +
+                  " equip=0x" + StringHelper::Sprintf("%X", gSaveContext.equips.equipment) +
+                  " tunicOwned=0x" + StringHelper::Sprintf("%X", gSaveContext.inventory.equipment));
+        logged = true;
+    }
+}
