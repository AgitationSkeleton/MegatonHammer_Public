+// Megaton Hammer: append a line to a boot log next to the executable, so the editor can verify
+// the auto-boot/warp ran (and how far it got) headlessly, without watching the screen.
+static void MhBootLog(const std::string& msg) {
+    std::ofstream f("mh_playtest_boot.log", std::ios::app);
+    if (f) {
+        f << msg << std::endl;
+    }
+}
