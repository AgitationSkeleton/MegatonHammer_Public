+// Megaton Hammer playtest diag: dedup-log lines to mh_tex_diag.log (spdlog's file sink is above ERROR
+// in release so the texture-handler's SPDLOG_ERROR misses are invisible). Used to pin the solid-red
+// skybox/Link render in editor-injected scenes. Defined here so it's visible to all interpreter funcs.
+static void MhTexDiag(const std::string& s) {
+    static std::set<std::string> seen;
+    if (seen.count(s)) return;
+    seen.insert(s);
+    std::ofstream f("mh_tex_diag.log", std::ios::app);
+    if (f.is_open()) f << s << std::endl;
+}
