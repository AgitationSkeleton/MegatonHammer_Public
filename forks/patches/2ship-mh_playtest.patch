+// Megaton Hammer: warp into a level packed by the editor's "Playtest" action. The editor writes
+// its level as native OTR resources that override a chosen scene's archive paths (mods/mh_playtest.o2r),
+// so the scene already loads normally — this command just warps there. The scene id is the MM scene
+// table index the editor packed against. Usage: mh_playtest [sceneIdHex]
+static bool MhPlaytestHandler(std::shared_ptr<Ship::Console> Console, const std::vector<std::string>& args,
+                              std::string* output) {
+    if (gPlayState == nullptr) {
+        ERROR_MESSAGE("[2S2H] Load a save file first, then run mh_playtest.");
+        return 1;
+    }
+
+    s32 sceneId = 0x52; // matches Megaton Hammer's default playtest slot
+    if (args.size() >= 2) {
+        try {
+            sceneId = std::stoi(args[1], nullptr, 16);
+        } catch ([[maybe_unused]] std::invalid_argument const& ex) {
+            ERROR_MESSAGE("[2S2H] Scene id must be a hex number.");
+            return 1;
+        }
+    }
+
+    // MM encodes an entrance as (entranceSceneIndex << 9) | (spawn << 4); the scene-index is NOT the
+    // scene id, so scan the table for the first entrance (spawn 0) that resolves to the target scene.
+    s32 entrance = -1;
+    for (u32 i = 0; i < ENTR_SCENE_MAX; i++) {
+        if (sSceneEntranceTable[i].table == NULL) {
+            continue; // SCENE_ENTRANCE_NONE slot — would crash in Entrance_GetSceneIdAbsolute
+        }
+        u16 cand = (u16)(i << 9);
+        if (Entrance_GetSceneIdAbsolute(cand) == sceneId) {
+            entrance = cand;
+            break;
+        }
+    }
+    if (entrance < 0) {
+        ERROR_MESSAGE("[2S2H] No entrance found for scene id 0x%X.", sceneId);
+        return 1;
+    }
+
+    gPlayState->nextEntrance = entrance;
+    gPlayState->transitionTrigger = TRANS_TRIGGER_START;
+    gPlayState->transitionType = TRANS_TYPE_INSTANT;
+    gSaveContext.nextTransitionType = TRANS_TYPE_INSTANT;
+    return 0;
+}
