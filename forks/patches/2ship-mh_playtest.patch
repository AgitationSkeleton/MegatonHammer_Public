+// Cross-game / custom music: the runtime seqId->resource-path map, built by AudioLoad_Init from the archives.
+// The boot hook force-rebinds a host slot to the editor's injected OSEQ resource (see MhPlaytestBootHook).
+extern "C" char** gSequenceMap;
+extern "C" size_t gSequenceMapSize;
+
+// Megaton Hammer: on startup, if the editor's playtest mod O2R is mounted (it carries "mh/info"),
+// set up a save and warp straight into the packed MM scene — no manual console command. Modelled
+// on DeveloperTools/WarpPoint.cpp's boot path (MM save/entrance system).
+static void MhPlaytestBootHook() {
+    static bool done = false;
+    if (done) {
+        return;
+    }
+    // Only auto-warp before gameplay starts (boot). Once in-game, leave the player alone.
+    if (gPlayState != NULL) {
+        return;
+    }
+    static int diag = 0;
+    if (diag == 0) {
+        MhBootLog("[mh_boot] hook firing");
+    }
+    auto ctx = Ship::Context::GetInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) {
+        if (diag++ < 3) MhBootLog("[mh_boot] no resource manager yet");
+        return;
+    }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/info");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) {
+        if (diag++ < 3) MhBootLog("[mh_boot] mh/info not found yet");
+        return; // no playtest mod present → normal boot
+    }
+    done = true;
+
+    MhLoadMessages();   // register any authored dialogue (mh/messages) before warping in
+
+    std::string info(file->Buffer->begin(), file->Buffer->end());
+    MhBootLog("[mh_boot] mh/info loaded: " + info);
+    nlohmann::json j = nlohmann::json::parse(info, nullptr, false);
+    if (j.is_discarded()) {
+        MhBootLog("[mh_boot] FAIL: mh/info JSON parse error");
+        return;
+    }
+    s32 sceneId = j.value("sceneId", 0x08);
+    bool append = j.value("append", false);
+    std::string inv = j.value("inventory", std::string("debug"));
+    MhBootLog("[mh_boot] sceneId=" + std::to_string(sceneId) + " inventory=" + inv +
+              " append=" + std::to_string(append));
+
+    // #20: label this level at the tail of the debug scene-select list (default "Megaton Project").
+    {
+        std::string dn = j.value("displayName", std::string("Megaton Project"));
+        if (dn.empty()) dn = "Megaton Project";
+        snprintf(gMhWarpName, sizeof(gMhWarpName), "X 2:%.58s", dn.c_str());
+        MhBootLog("[mh_boot] warp-list name = " + std::string(gMhWarpName));
+    }
+
+    // Megaton Hammer cross-game / custom music: the editor packed the chosen sequence as an OSEQ resource
+    // (audio/sequences/mh_cross) that claims a valid vanilla host seqId, and recorded it in mh/info "music".
+    // AudioLoad_Init already built gSequenceMap from every archive, but two resources sharing a seqNumber are
+    // last-writer-wins (nondeterministic). Force the host slot to our resource so the scene's 0x15 (which the
+    // editor set to that same host id) resolves to the injected track. The level is custom, so displacing that
+    // vanilla sequence for this session is harmless.
+    if (j.contains("music") && j["music"].is_object() && gSequenceMap != nullptr) {
+        int mSeq = j["music"].value("seqId", -1);
+        std::string mPath = j["music"].value("path", std::string());
+        if (mSeq >= 0 && (size_t)mSeq < gSequenceMapSize && !mPath.empty()) {
+            if (gSequenceMap[mSeq] != nullptr) {
+                free(gSequenceMap[mSeq]);
+            }
+            gSequenceMap[mSeq] = strdup(mPath.c_str());
+            MhBootLog("[mh_boot] music: gSequenceMap[" + std::to_string(mSeq) + "] -> " + mPath);
+        } else {
+            MhBootLog("[mh_boot] music: invalid seqId/path (seqId=" + std::to_string(mSeq) +
+                      ", mapSize=" + std::to_string(gSequenceMapSize) + ")");
+        }
+    }
+
+    // Resolve the warp entrance. Append mode targets the reserved SCENE_MH_APPEND scene reached via
+    // the reserved ENTR_SCENE_MH_APPEND entrance-scene — both added to the (grown) scene table,
+    // EntranceSceneId enum and sSceneEntranceTable in the Megaton Hammer fork, so nothing existing is
+    // repurposed. gSceneTable[SCENE_MH_APPEND] statically references scenes/nonmq/mh_append/mh_append,
+    // which our mod O2R overrode with the appended level. Replace mode scans for the first entrance
+    // (spawn 0) that resolves to the chosen real scene id.
+    s32 entrance = -1;
+    if (append) {
+        entrance = (s32)(ENTR_SCENE_MH_APPEND << 9);   // (entranceSceneIndex << 9) | (spawn 0 << 4)
+        MhBootLog("[mh_boot] append mode — warping via reserved ENTR_SCENE_MH_APPEND -> SCENE_MH_APPEND");
+    } else {
+        // MM encodes an entrance as (sceneIndex << 9) | (spawn << 4). Skip SCENE_ENTRANCE_NONE slots
+        // (null table) — dereferencing those in Entrance_GetSceneIdAbsolute crashed at boot.
+        for (u32 i = 0; i < ENTR_SCENE_MAX; i++) {
+            if (sSceneEntranceTable[i].table == NULL) {
+                continue;
+            }
+            u16 cand = (u16)(i << 9);
+            if (Entrance_GetSceneIdAbsolute(cand) == sceneId) {
+                entrance = cand;
+                break;
+            }
+        }
+        if (entrance < 0) {
+            MhBootLog("[mh_boot] FAIL: no entrance found for replace-mode scene id");
+            return;
+        }
+    }
+    MhBootLog("[mh_boot] entrance=" + std::to_string(entrance));
+
+    // Boot a save and warp in — mirrors WarpPoint.cpp / MapSelect_LoadGame.
+    gSaveContext.gameMode = GAMEMODE_NORMAL;
+    if (inv == "empty" || inv == "custom") {
+        // Empty/custom start: fresh save, bypass MapSelect's debug-save init via dummy file num.
+        // For "custom" the editor's loadout is layered on after the fresh save (below).
+        Sram_InitNewSave();
+        gSaveContext.sceneLayer = 0;
+        for (size_t i = 0; i < ARRAY_COUNT(gSaveContext.eventInf); i++) {
+            gSaveContext.eventInf[i] = 0;
+        }
+        for (int i = 0; i < ARRAY_COUNT(gSaveContext.cycleSceneFlags); i++) {
+            gSaveContext.cycleSceneFlags[i].chest = gSaveContext.save.saveInfo.permanentSceneFlags[i].chest;
+            gSaveContext.cycleSceneFlags[i].switch0 = gSaveContext.save.saveInfo.permanentSceneFlags[i].switch0;
+            gSaveContext.cycleSceneFlags[i].switch1 = gSaveContext.save.saveInfo.permanentSceneFlags[i].switch1;
+            gSaveContext.cycleSceneFlags[i].clearedRoom = gSaveContext.save.saveInfo.permanentSceneFlags[i].clearedRoom;
+            gSaveContext.cycleSceneFlags[i].collectible = gSaveContext.save.saveInfo.permanentSceneFlags[i].collectible;
+        }
+        if (inv == "custom" && j.contains("inv") && j["inv"].is_object()) {
+            MhApplyCustomInventory(j["inv"]);
+            MhBootLog("[mh_boot] applied custom inventory");
+        }
+        gSaveContext.fileNum = 0xFE;
+        MapSelect_LoadGame((MapSelectState*)gGameState, entrance, 0);
+        gSaveContext.fileNum = 0xFF;
+        GameInteractor_ExecuteOnSaveInit(gSaveContext.fileNum);
+        GameInteractor_ExecuteOnSaveLoad(gSaveContext.fileNum);
+    } else {
+        // "debug" (and, for now, "custom"): the debug file num makes MapSelect_LoadGame run
+        // Sram_InitDebugSave — MM's full debug inventory — and clear flags + fire OnSaveLoad.
+        gSaveContext.fileNum = 0xFF;
+        MapSelect_LoadGame((MapSelectState*)gGameState, entrance, 0);
+    }
+    gSaveContext.save.entrance = entrance;
+
+    // MH playtest gamestate normalization: apply for ALL inventory modes (empty/custom/debug) so the
+    // playtest starts in the same world-state regardless of the inventory toggle. Previously these were
+    // set only on the empty/custom path; the "debug" path inherited MapSelect_LoadGame / Sram_InitDebugSave
+    // defaults (different day/time/form), so toggling inventory silently changed time-of-day, form and the
+    // 3-day cycle — and any time-gated (half-day) actor's spawn outcome with it.
+    // Normalized playtest time-of-day (editor SceneSettings.PlaytestTimeOfDay): one u16 over a 24h day
+    // from midnight (0x8000=noon), the SAME value/convention SoH applies to dayTime — every engine starts
+    // at the identical time. Default noon if absent.
+    gSaveContext.save.time = (j.contains("timeOfDay") && j["timeOfDay"].is_number_integer())
+                                 ? (u16)j["timeOfDay"].get<int>() : 0x8000;
+    gSaveContext.save.day = 1;
+    gSaveContext.save.cutsceneIndex = 0;
+    gSaveContext.save.playerForm = PLAYER_FORM_HUMAN;
+    gSaveContext.save.linkAge = 0;
+
+    // Megaton Hammer playtest: every authored chest must appear. The debug save (Sram_InitDebugSave) and
+    // a loaded save can leave the test scene's chest/switch flags set, so En_Box despawns as already-opened
+    // — exactly why the chest showed on the N64 PJ64 path (whose Play_Init detour zeroes cycleSceneFlags
+    // wholesale) but not here. Mirror that: clear all cycle scene chest/switch flags so chests start closed
+    // and switches unpressed for a fresh test. (collectible/clearedRoom left as-is.)
+    for (int i = 0; i < ARRAY_COUNT(gSaveContext.cycleSceneFlags); i++) {
+        gSaveContext.cycleSceneFlags[i].chest = 0;
+        gSaveContext.cycleSceneFlags[i].switch0 = 0;
+        gSaveContext.cycleSceneFlags[i].switch1 = 0;
+    }
+
+    // Starting weekEventReg flags (custom-engine convention): pre-set the scene's world-state (e.g. a
+    // temple already cleared). Each value is PACK_WEEKEVENTREG_FLAG = (byteIndex<<8)|bitMask.
+    if (j.contains("weekEvents") && j["weekEvents"].is_array()) {
+        int wn = 0;
+        for (auto& f : j["weekEvents"]) {
+            if (f.is_number_integer()) { SET_WEEKEVENTREG((u16)f.get<int>()); wn++; }
+        }
+        if (wn > 0) MhBootLog("[mh_boot] set " + std::to_string(wn) + " starting week-event flag(s)");
+    }
+
+    // weekEventReg cross-cycle persistence (decomp: sPersistentCycleWeekEventRegs in z_sram_NES.c). MM
+    // clears most weekEventReg flags on a Song-of-Time reset; only flags whose 2-bit slot in that table
+    // is non-zero survive. We OR the editor's persistent flags into the engine's OWN table, so the
+    // engine's reset logic naturally preserves them — no separate reset hook needed. Each flag is
+    // PACK_WEEKEVENTREG_FLAG = (byteIndex<<8)|mask; the table slot is (3 << (2 * shiftOfMask)).
+    if (j.contains("persistentWeekEvents") && j["persistentWeekEvents"].is_array()) {
+        int pn = 0;
+        for (auto& f : j["persistentWeekEvents"]) {
+            if (!f.is_number_integer()) continue;
+            u16 flag = (u16)f.get<int>();
+            int byteIndex = (flag >> 8) & 0xFF, mask = flag & 0xFF;
+            if (byteIndex < 0 || byteIndex >= 100 || mask == 0) continue;
+            int shift = 0; while (shift < 7 && !((mask >> shift) & 1)) shift++;
+            sPersistentCycleWeekEventRegs[byteIndex] |= (u16)(3 << (2 * shift));
+            pn++;
+        }
+        if (pn > 0) MhBootLog("[mh_boot] marked " + std::to_string(pn) + " week-event flag(s) cross-cycle persistent");
+    }
+
+    MhBootLog("[mh_boot] OK: warp triggered to scene " + std::to_string(sceneId));
+}
+
+// MH render probe: once we've actually entered the playtest scene and run a few frames, log it once.
+// Positive confirmation the level loaded AND is rendering frames (not just that the warp fired) — lets
+// the headless MM harness distinguish a real load from a post-warp freeze.
+static void MhPlaytestRenderProbe() {
+    static int framesInScene = 0;
+    static bool logged = false;
+    if (gPlayState == nullptr) {
+        return;
+    }
+    if (gPlayState->sceneId != SCENE_MH_APPEND) {
+        framesInScene = 0;
+        return;
+    }
+    framesInScene++;
+    // #5: re-assert the editor's Z-targeting mode for the first ~90 frames, in case MM's options load
+    // (which runs after the boot hook) reverts the write.
+    if (sMhZTarget >= 0 && framesInScene <= 90) {
+        gSaveContext.options.zTargetSetting = (u8)sMhZTarget;
+    }
+    if (logged) {
+        return;
+    }
+    if (framesInScene >= 30) {
+        // MH diag: at frame 30 the room's actors have finished spawning, so this is a CONCLUSIVE count
+        // (the earlier room-load count ran before deferred spawns). Lists every actor id so a chest
+        // (En_Box 0x06) that the editor exported but the engine drops/rejects is visible in the log.
+        int chestN = 0, total = 0; std::string ids;
+        for (int c = 0; c < ACTORCAT_MAX; c++)
+            for (Actor* a = gPlayState->actorCtx.actorLists[c].first; a != NULL; a = a->next) {
+                total++;
+                if (a->id == ACTOR_EN_BOX) chestN++;
+                char buf[12]; snprintf(buf, sizeof(buf), "%X ", a->id); ids += buf;
+            }
+        // A-button diag: it's still missing despite HUD_VISIBILITY_ALL + RESTRICTIONS_NONE. Log the
+        // gates that can suppress it: hudVisibility, the A button-status, the live cutscene id, and the
+        // scene restriction bit — so the actual suppressor is visible in the log.
+        MhBootLog("[mh_boot] RENDER OK: in SCENE_MH_APPEND room=" +
+                  std::to_string((int)gPlayState->roomCtx.curRoom.num) + " after 30 frames; actors total=" +
+                  std::to_string(total) + " En_Box=" + std::to_string(chestN) + " ids=[" + ids + "]");
+        MhBootLog("[mh_diag] A-button: hudVisibility=" + std::to_string((int)gSaveContext.hudVisibility) +
+                  " buttonStatus[A]=" + std::to_string((int)gSaveContext.buttonStatus[EQUIP_SLOT_A]) +
+                  " curCsId=" + std::to_string((int)CutsceneManager_GetCurrentCsId()) +
+                  " restrict.aButton=" + std::to_string((int)gPlayState->interfaceCtx.restrictions.aButton));
+        // Object diag: En_Box (chest) is correctly exported but doesn't spawn while En_Horse (same room)
+        // does. Both objects are in the room's object list. Log which objects actually LOADED — if
+        // object_box (0x0C) is missing, that's why En_Box never spawns (Actor_Spawn fails the dependency).
+        {
+            std::string objs;
+            for (int i = 0; i < gPlayState->objectCtx.numEntries; i++) {
+                char ob[8]; snprintf(ob, sizeof(ob), "%X ", (int)gPlayState->objectCtx.slots[i].id); objs += ob;
+            }
+            MhBootLog("[mh_diag] objects: box(0x0C)slot=" +
+                      std::to_string((int)Object_GetSlot(&gPlayState->objectCtx, 0x0C)) +
+                      " horse(0x7D)slot=" + std::to_string((int)Object_GetSlot(&gPlayState->objectCtx, 0x7D)) +
+                      " loaded=[" + objs + "]");
+        }
+        logged = true;
+    }
+}
+
+// ── MH NPC schedules (custom-engine convention) ─────────────────────────────────────────────────
+// The editor's mod O2R may carry "mh/schedules": a list of actors that should be at a given position/
+// facing during a time/day window. We apply them each frame by overriding the actor's world position —
+// this is what lets a Megaton-Hammer MM town be populated by the clock without authoring the actor's
+// internal schedule bytecode. Actors are re-found by id each frame (no cached pointers → no dangling).
+struct MhSchedRule { int day, sh, sm, eh, em, x, y, z; short yaw; };
+struct MhSchedEntry { int room, id, x, y, z; std::vector<MhSchedRule> rules; };
+static std::vector<MhSchedEntry> sMhSchedules;
+static bool sMhSchedLoaded = false;
+
+static void MhLoadSchedules() {
+    sMhSchedLoaded = true;
+    auto ctx = Ship::Context::GetInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) { sMhSchedLoaded = false; return; }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/schedules");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) return; // none → nothing to do
+    std::string s(file->Buffer->begin(), file->Buffer->end());
+    auto j = nlohmann::json::parse(s, nullptr, false);
+    if (j.is_discarded() || !j.is_array()) { MhBootLog("[mh_sched] parse error"); return; }
+    for (auto& e : j) {
+        MhSchedEntry se{};
+        se.room = e.value("room", -1); se.id = e.value("id", 0);
+        se.x = e.value("x", 0); se.y = e.value("y", 0); se.z = e.value("z", 0);
+        if (e.contains("rules") && e["rules"].is_array())
+            for (auto& r : e["rules"]) {
+                MhSchedRule rr{};
+                rr.day = r.value("day", 0); rr.sh = r.value("sh", 0); rr.sm = r.value("sm", 0);
+                rr.eh = r.value("eh", 23); rr.em = r.value("em", 59);
+                rr.x = r.value("x", 0); rr.y = r.value("y", 0); rr.z = r.value("z", 0); rr.yaw = (short)r.value("yaw", 0);
+                se.rules.push_back(rr);
+            }
+        sMhSchedules.push_back(se);
+    }
+    MhBootLog("[mh_sched] loaded " + std::to_string(sMhSchedules.size()) + " scheduled actor(s)");
+}
+
+static const MhSchedRule* MhActiveRule(const MhSchedEntry& e) {
+    int day = CURRENT_DAY;
+    int totalMin = (int)((u32)gSaveContext.save.time * 1440u / 0x10000u);
+    int now = totalMin; // minutes since midnight
+    for (auto& r : e.rules) {
+        if (r.day != 0 && r.day != day) continue;
+        int s = r.sh * 60 + r.sm, en = r.eh * 60 + r.em;
+        bool in = (s <= en) ? (now >= s && now <= en) : (now >= s || now <= en);
+        if (in) return &r;
+    }
+    return nullptr;
+}
+
+static void MhScheduleHook() {
+    if (!sMhSchedLoaded) MhLoadSchedules();
+    if (sMhSchedules.empty() || gPlayState == nullptr || gPlayState->sceneId != SCENE_MH_APPEND) return;
+    for (auto& e : sMhSchedules) {
+        const MhSchedRule* r = MhActiveRule(e);
+        if (r == nullptr) continue;
+        // Re-find the actor of this id nearest the placed position each frame (no cached pointer).
+        Actor* best = nullptr; float bestD = 1e30f;
+        for (int c = 0; c < ACTORCAT_MAX; c++)
+            for (Actor* a = gPlayState->actorCtx.actorLists[c].first; a != nullptr; a = a->next) {
+                if (a->id != e.id) continue;
+                float dx = a->world.pos.x - e.x, dy = a->world.pos.y - e.y, dz = a->world.pos.z - e.z;
+                float d = dx * dx + dy * dy + dz * dz;
+                if (d < bestD) { bestD = d; best = a; }
+            }
+        if (best != nullptr) {
+            best->world.pos.x = (f32)r->x; best->world.pos.y = (f32)r->y; best->world.pos.z = (f32)r->z;
+            best->world.rot.y = r->yaw; best->shape.rot.y = r->yaw;
+        }
+    }
+}
+
+// ── MH schedule bytecode VM (decomp z_schedule.c) ───────────────────────────────────────────────
+// The editor's mod O2R may carry "mh/schedule_vm": actors with an authored schedule SCRIPT (the real
+// MM 19-opcode bytecode) plus a pose table. Unlike mh/schedules (position rules), this runs the actual
+// engine VM — Schedule_RunScript — every frame and applies poses[output.result], or hides the actor when
+// the script returns nothing (RET_NONE). This makes a fully decomp-faithful schedule authorable in-editor.
+struct MhSchedPose { int x, y, z; short yaw; };
+struct MhVmEntry { int room, id, x, y, z; std::vector<u8> code; std::vector<MhSchedPose> poses; };
+static std::vector<MhVmEntry> sMhVmEntries;
+static bool sMhVmLoaded = false;
+
+static void MhLoadScheduleVm() {
+    sMhVmLoaded = true;
+    auto ctx = Ship::Context::GetInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) { sMhVmLoaded = false; return; }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/schedule_vm");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) return;
+    std::string s(file->Buffer->begin(), file->Buffer->end());
+    auto j = nlohmann::json::parse(s, nullptr, false);
+    if (j.is_discarded() || !j.is_array()) { MhBootLog("[mh_vm] parse error"); return; }
+    for (auto& e : j) {
+        MhVmEntry ve{};
+        ve.room = e.value("room", -1); ve.id = e.value("id", 0);
+        ve.x = e.value("x", 0); ve.y = e.value("y", 0); ve.z = e.value("z", 0);
+        std::string hex = e.value("code", std::string());
+        for (size_t i = 0; i + 1 < hex.size(); i += 2)
+            ve.code.push_back((u8)std::stoul(hex.substr(i, 2), nullptr, 16));
+        if (e.contains("poses") && e["poses"].is_array())
+            for (auto& p : e["poses"]) {
+                MhSchedPose pp{};
+                pp.x = p.value("x", 0); pp.y = p.value("y", 0); pp.z = p.value("z", 0); pp.yaw = (short)p.value("yaw", 0);
+                ve.poses.push_back(pp);
+            }
+        if (!ve.code.empty()) sMhVmEntries.push_back(ve);
+    }
+    MhBootLog("[mh_vm] loaded " + std::to_string(sMhVmEntries.size()) + " schedule-VM actor(s)");
+}
+
+static void MhScheduleVmHook() {
+    if (!sMhVmLoaded) MhLoadScheduleVm();
+    if (sMhVmEntries.empty() || gPlayState == nullptr || gPlayState->sceneId != SCENE_MH_APPEND) return;
+    for (auto& e : sMhVmEntries) {
+        // Re-find the live actor of this id nearest the placed position each frame (no cached pointer).
+        Actor* best = nullptr; float bestD = 1e30f;
+        for (int c = 0; c < ACTORCAT_MAX; c++)
+            for (Actor* a = gPlayState->actorCtx.actorLists[c].first; a != nullptr; a = a->next) {
+                if (a->id != e.id) continue;
+                float dx = a->world.pos.x - e.x, dy = a->world.pos.y - e.y, dz = a->world.pos.z - e.z;
+                float d = dx * dx + dy * dy + dz * dz;
+                if (d < bestD) { bestD = d; best = a; }
+            }
+        if (best == nullptr) continue;
+        ScheduleOutput output;
+        output.result = 0; output.hasResult = false; output.time0 = output.time1 = 0;
+        Schedule_RunScript(gPlayState, e.code.data(), &output);
+        if (output.hasResult && !e.poses.empty()) {
+            int idx = output.result; if (idx < 0) idx = 0; if (idx >= (int)e.poses.size()) idx = (int)e.poses.size() - 1;
+            const MhSchedPose& p = e.poses[idx];
+            best->world.pos.x = (f32)p.x; best->world.pos.y = (f32)p.y; best->world.pos.z = (f32)p.z;
+            best->world.rot.y = p.yaw; best->shape.rot.y = p.yaw;
+        } else {
+            // RET_NONE / no poses → the schedule says "not present now": park the actor far below the world.
+            best->world.pos.y = -30000.0f;
+        }
+    }
+}
