+// Megaton Hammer: apply a custom starting inventory (from the editor's inventory editor) onto a
+// fresh MM save. Payload = the "inv" object of mh/info: { hearts, tiers{...}, toggles[...] }.
+// Keys match Editor/InventoryCatalog (MM). Call after Sram_InitNewSave, before MapSelect_LoadGame.
+// #5: editor's Z-targeting mode, re-asserted by the render probe (MM re-loads options after our hook). -1 = none.
+static int sMhZTarget = -1;
+static void MhApplyCustomInventory(const nlohmann::json& inv) {
+    int hearts = inv.value("hearts", 3);
+    gSaveContext.save.saveInfo.playerData.healthCapacity = (s16)(hearts * 16);
+    gSaveContext.save.saveInfo.playerData.health = gSaveContext.save.saveInfo.playerData.healthCapacity;
+
+    auto hasToggle = [&](const char* k) -> bool {
+        if (!inv.contains("toggles") || !inv["toggles"].is_array()) return false;
+        for (auto& t : inv["toggles"]) if (t.is_string() && t.get<std::string>() == k) return true;
+        return false;
+    };
+    auto tier = [&](const char* k) -> int {
+        if (inv.contains("tiers") && inv["tiers"].is_object() && inv["tiers"].contains(k))
+            return inv["tiers"][k].get<int>();
+        return 0;
+    };
+    auto amount = [&](const char* k) -> int {   // #13: varying-amount item count (0 = none)
+        if (inv.contains("amounts") && inv["amounts"].is_object() && inv["amounts"].contains(k))
+            return inv["amounts"][k].get<int>();
+        return 0;
+    };
+
+    // #21: injected player name (default "Link"). MM shares OoT's filename encoding: 0-9=0x00..,
+    // A-Z=0x0A.., a-z=0x24.., space/other=0x3E; padded to 8 ("LINK" = 15 12 17 14 3E..).
+    {
+        std::string pn = inv.value("playerName", std::string("Link"));
+        if (pn.empty()) pn = "Link";
+        for (int i = 0; i < 8; i++) {
+            char c = 0x3E;
+            if (i < (int)pn.size()) {
+                char ch = pn[i];
+                if (ch >= '0' && ch <= '9') c = (char)(ch - '0');
+                else if (ch >= 'A' && ch <= 'Z') c = (char)(0x0A + (ch - 'A'));
+                else if (ch >= 'a' && ch <= 'z') c = (char)(0x24 + (ch - 'a'));
+            }
+            gSaveContext.save.saveInfo.playerData.playerName[i] = c;
+        }
+    }
+
+    // #5: Z-targeting mode (0 = Switch/Toggle, 1 = Hold). MM stores it in SaveContext.options. Stash it so
+    // the render probe re-asserts it after MM's options load (later in boot) reverts this write.
+    sMhZTarget = inv.value("zTarget", 0);
+    gSaveContext.options.zTargetSetting = (u8)sMhZTarget;
+
+    // Sword / shield (equip the chosen tier; EQUIP_VALUE_*_x are 1-based).
+    int sw = tier("sword");
+    if (sw > 0) {
+        static const u8 swordVal[] = { EQUIP_VALUE_SWORD_KOKIRI, EQUIP_VALUE_SWORD_RAZOR, EQUIP_VALUE_SWORD_GILDED };
+        SET_EQUIP_VALUE(EQUIP_TYPE_SWORD, swordVal[(sw - 1) % 3]);
+    }
+    int sh = tier("shield");
+    if (sh > 0) {
+        static const u8 shieldVal[] = { EQUIP_VALUE_SHIELD_HERO, EQUIP_VALUE_SHIELD_MIRROR };
+        SET_EQUIP_VALUE(EQUIP_TYPE_SHIELD, shieldVal[(sh - 1) % 2]);
+    }
+
+    // Upgrades (wallet / quiver / bomb bag).
+    if (tier("wallet"))  Inventory_ChangeUpgrade(UPG_WALLET, tier("wallet"));
+    if (tier("quiver"))  Inventory_ChangeUpgrade(UPG_QUIVER, tier("quiver"));
+    if (tier("bombbag")) Inventory_ChangeUpgrade(UPG_BOMB_BAG, tier("bombbag"));
+
+    // Magic tier: 1 = single (first upgrade), 2 = double. Same fields SaveEditor.cpp sets:
+    // flag acquired + magicLevel, derive magicCapacity = level*MAGIC_NORMAL_METER, fill the meter.
+    int mg = tier("magic");
+    if (mg >= 1) {
+        gSaveContext.save.saveInfo.playerData.isMagicAcquired = true;
+        gSaveContext.save.saveInfo.playerData.magicLevel = (mg >= 2) ? 2 : 1;
+        if (mg >= 2) gSaveContext.save.saveInfo.playerData.isDoubleMagicAcquired = true;
+        gSaveContext.magicCapacity = gSaveContext.save.saveInfo.playerData.magicLevel * MAGIC_NORMAL_METER;
+        gSaveContext.save.saveInfo.playerData.magic = gSaveContext.magicCapacity;
+    }
+
+    // Masks (a mask is owned when its inventory slot holds its item id).
+    struct ItemDef { const char* key; u16 item; s8 ammo; };
+    static const ItemDef kMasks[] = {
+        { "mask_postman", ITEM_MASK_POSTMAN, 0 }, { "mask_allnight", ITEM_MASK_ALL_NIGHT, 0 }, { "mask_blast", ITEM_MASK_BLAST, 0 },
+        { "mask_stone", ITEM_MASK_STONE, 0 }, { "mask_greatfairy", ITEM_MASK_GREAT_FAIRY, 0 }, { "mask_deku", ITEM_MASK_DEKU, 0 },
+        { "mask_keaton", ITEM_MASK_KEATON, 0 }, { "mask_bremen", ITEM_MASK_BREMEN, 0 }, { "mask_bunny", ITEM_MASK_BUNNY, 0 },
+        { "mask_dongero", ITEM_MASK_DON_GERO, 0 }, { "mask_scents", ITEM_MASK_SCENTS, 0 }, { "mask_goron", ITEM_MASK_GORON, 0 },
+        { "mask_romani", ITEM_MASK_ROMANI, 0 }, { "mask_circus", ITEM_MASK_CIRCUS_LEADER, 0 }, { "mask_kafei", ITEM_MASK_KAFEIS_MASK, 0 },
+        { "mask_couple", ITEM_MASK_COUPLE, 0 }, { "mask_truth", ITEM_MASK_TRUTH, 0 }, { "mask_zora", ITEM_MASK_ZORA, 0 },
+        { "mask_kamaro", ITEM_MASK_KAMARO, 0 }, { "mask_gibdo", ITEM_MASK_GIBDO, 0 }, { "mask_garo", ITEM_MASK_GARO, 0 },
+        { "mask_captain", ITEM_MASK_CAPTAIN, 0 }, { "mask_giant", ITEM_MASK_GIANT, 0 }, { "mask_fierce", ITEM_MASK_FIERCE_DEITY, 0 },
+    };
+    for (auto& m : kMasks) if (hasToggle(m.key)) INV_CONTENT(m.item) = (u8)m.item;
+
+    // Deku Link's B-button (bubble/nut) is driven entirely by equips.buttonItems[PLAYER_FORM_DEKU][EQUIP_SLOT_B]
+    // == ITEM_DEKU_NUT (see z_parameter.c ~3123: with magic it fires bubbles, without magic the game disables it).
+    // A legit playthrough sets this when the Deku mask is used; granting the mask directly via INV_CONTENT skips
+    // that, leaving the default sSaveDefaultItemEquips value ITEM_FD, so Deku Link's B does nothing. Restore it
+    // verbatim from 2Ship's own sSaveDebugItemEquips Deku row (buttonItems[3][0] = ITEM_DEKU_NUT) — the same value
+    // the N64 debug save uses, which is why Deku's B already works on PJ64.
+    if (hasToggle("mask_deku")) {
+        BUTTON_ITEM_EQUIP(PLAYER_FORM_DEKU, EQUIP_SLOT_B) = ITEM_DEKU_NUT;
+    }
+
+    // Items (with starting ammo where applicable).
+    static const ItemDef kItems[] = {
+        { "ocarina", ITEM_OCARINA_OF_TIME, 0 }, { "bow", ITEM_BOW, 30 }, { "bomb", ITEM_BOMB, 20 }, { "bombchu", ITEM_BOMBCHU, 20 },
+        { "bean", ITEM_MAGIC_BEANS, 0 }, { "powder_keg", ITEM_POWDER_KEG, 0 }, { "pictograph", ITEM_PICTOGRAPH_BOX, 0 },
+        { "lens", ITEM_LENS_OF_TRUTH, 0 }, { "hookshot", ITEM_HOOKSHOT, 0 }, { "great_fairy_sword", ITEM_SWORD_GREAT_FAIRY, 0 },
+        { "bottle", ITEM_BOTTLE, 0 },
+    };
+    for (auto& it : kItems)
+        if (hasToggle(it.key)) { INV_CONTENT(it.item) = (u8)it.item; if (it.ammo) AMMO(it.item) = it.ammo; }
+
+    // #13: varying-amount items — count sets ammo[] and auto-grants the requisite capacity upgrade
+    // (highest of explicit tier vs derived wins). MM has no deku-stick upgrade, so sticks cap at 10.
+    struct AmmoDef { const char* key; u16 item; int upg; u8 caps[4]; };
+    static const AmmoDef kAmmo[] = {
+        { "bow", ITEM_BOW, UPG_QUIVER, {0,30,40,50} }, { "bomb", ITEM_BOMB, UPG_BOMB_BAG, {0,20,30,40} },
+        { "bombchu", ITEM_BOMBCHU, -1, {0,50,50,50} }, { "stick", ITEM_DEKU_STICK, -1, {0,10,10,10} },
+        { "nut", ITEM_DEKU_NUT, UPG_DEKU_NUTS, {0,20,30,40} },
+    };
+    for (auto& a : kAmmo) {
+        int amt = amount(a.key);
+        if (amt <= 0) continue;
+        if (amt > a.caps[3]) amt = a.caps[3];
+        INV_CONTENT(a.item) = (u8)a.item;
+        AMMO(a.item) = (s8)amt;
+        if (a.upg >= 0) {
+            int lvl = 3;
+            for (int l = 1; l < 4; l++) if (a.caps[l] >= amt) { lvl = l; break; }
+            if (lvl > (int)CUR_UPG_VALUE(a.upg)) Inventory_ChangeUpgrade((u16)a.upg, lvl);
+        }
+    }
+
+    // Songs / remains (quest-item bits).
+    struct QuestDef { const char* key; int q; };
+    static const QuestDef kQuest[] = {
+        { "song_time", QUEST_SONG_TIME }, { "song_healing", QUEST_SONG_HEALING }, { "song_epona", QUEST_SONG_EPONA },
+        { "song_soaring", QUEST_SONG_SOARING }, { "song_storms", QUEST_SONG_STORMS }, { "song_awakening", QUEST_SONG_SONATA },
+        { "song_lullaby", QUEST_SONG_LULLABY }, { "song_bossa", QUEST_SONG_BOSSA_NOVA }, { "song_elegy", QUEST_SONG_ELEGY },
+        { "song_oath", QUEST_SONG_OATH }, { "song_saria", QUEST_SONG_SARIA }, { "song_suns", QUEST_SONG_SUN },
+        { "remains_odolwa", QUEST_REMAINS_ODOLWA }, { "remains_goht", QUEST_REMAINS_GOHT },
+        { "remains_gyorg", QUEST_REMAINS_GYORG }, { "remains_twinmold", QUEST_REMAINS_TWINMOLD },
+    };
+    for (auto& qq : kQuest)
+        if (hasToggle(qq.key)) gSaveContext.save.saveInfo.inventory.questItems |= gBitFlags[qq.q];
+
+    // Tatl: the fairy companion is a Save flag (the "bell_flag" @ save.hasTatl), not a quest item. On by
