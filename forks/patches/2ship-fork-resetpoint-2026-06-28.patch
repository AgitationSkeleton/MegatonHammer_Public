+// ── Authored dialogue (Megaton Hammer Message Bank) ───────────────────────────────────────────────
+// The editor emits an "mh/messages" resource: a JSON array of { id (textId), type, pos, icon, text }.
+// We register an OnOpenText hook per id; when an actor opens that textId we build the MM textbox from
+// the stored entry (friendly markup: & = newline, ^ = new box, %r/%g/%b/%y/%w/%p = colour) and load it
+// into the font, telling the engine to skip the normal message-table lookup. This generalises the
+// built-in single-id CustomMessage path (CUSTOM_MESSAGE_ID 0x4B) to an id-addressed bank.
+static std::unordered_map<u16, CustomMessage::Entry> sMhMessages;
+
+static void MhOnOpenText(u16* textId, bool* loadFromMessageTable) {
+    auto it = sMhMessages.find(*textId);
+    if (it == sMhMessages.end()) {
+        return; // not an authored id → let the normal table handle it
+    }
+    *loadFromMessageTable = false;
+    CustomMessage::LoadCustomMessageIntoFont(it->second);
+}
+
+static void MhLoadMessages() {
+    auto ctx = Ship::Context::GetInstance();
+    if (ctx == nullptr || ctx->GetResourceManager() == nullptr) {
+        return;
+    }
+    auto file = ctx->GetResourceManager()->GetArchiveManager()->LoadFile("mh/messages");
+    if (file == nullptr || file->Buffer == nullptr || file->Buffer->empty()) {
+        return; // no authored dialogue in this mod
+    }
+    std::string body(file->Buffer->begin(), file->Buffer->end());
+    nlohmann::json arr = nlohmann::json::parse(body, nullptr, false);
+    if (arr.is_discarded() || !arr.is_array()) {
+        MhBootLog("[mh_boot] mh/messages JSON parse error");
+        return;
+    }
+    int count = 0;
+    for (auto& e : arr) {
+        u16 id = (u16)e.value("id", 0);
+        if (id == 0) {
+            continue;
+        }
+        // Translate the editor's markup to what autoFormat expects: & → newline, ^ → MM box-break (0x10).
+        std::string text = e.value("text", std::string(""));
+        CustomMessage::Replace(&text, "&", "\n");
+        CustomMessage::Replace(&text, "^", "\x10");
+        int icon = e.value("icon", -1);
+        CustomMessage::Entry entry;
+        entry.textboxType = (uint8_t)e.value("type", 0);
+        entry.textboxYPos = (uint8_t)e.value("pos", 0);
+        entry.icon = (uint8_t)(icon < 0 ? 0xFE : icon);
+        entry.autoFormat = true;
+        entry.msg = text;
+        sMhMessages[id] = entry;
+        GameInteractor::Instance->RegisterGameHookForID<GameInteractor::OnOpenText>(id, MhOnOpenText);
+        count++;
+    }
+    MhBootLog("[mh_msg] registered " + std::to_string(count) + " authored message(s)");
+}
