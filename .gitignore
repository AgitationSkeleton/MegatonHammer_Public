levelout/
**/tex_dump/
*_top.png
*_iso.png
*_cam*.png

# ---- Misc ----
*.log
Thumbs.db
.DS_Store

# Fork full-snapshot backups (not the minimal delta; bake in machine paths)
forks/patches/*resetpoint*.patch
